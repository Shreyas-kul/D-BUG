# LLM Provider (groq | ollama | huggingface)
DBUG_LLM_PROVIDER=groq

# Groq — Free at https://console.groq.com
GROQ_API_KEY=

# HuggingFace — Free at https://huggingface.co/settings/tokens
HF_API_TOKEN=

# DuckDuckGo Search — No API key needed! 100% free.

# GitHub — Free personal access token
GITHUB_TOKEN=

# Sentry — Free at https://sentry.io
SENTRY_DSN=

# Ollama — No key needed, just install: brew install ollama
# OLLAMA_HOST=http://localhost:11434
